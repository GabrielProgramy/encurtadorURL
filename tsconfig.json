{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": ".",
		"declaration": false
	},
	"include": [
		"src/**/*",
		"generated/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}